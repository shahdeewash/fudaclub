# =============================================================================
# FÜDA Club — Environment variables
# Copy this file to .env for local dev, or set each variable in Railway's
# Variables tab for production. NEVER commit a real .env file to git.
# =============================================================================

# ── App identity ──────────────────────────────────────────────────────────────
# Stable identifier baked into JWT cookies. Don't change after launch or all
# active sessions will be invalidated.
VITE_APP_ID=fudaclub

# Public URL of THIS deployment. On Railway, paste the auto-assigned domain
# (e.g. https://fudaclub-production.up.railway.app). After custom domain DNS
# is live, change to https://fudaclub.com.au (or whatever the live domain is).
PUBLIC_URL=https://fudaclub-production.up.railway.app

# ── Database ──────────────────────────────────────────────────────────────────
# Auto-injected by Railway when you attach a MySQL plugin. Do NOT set manually.
# Format: mysql://user:pass@host:port/db
DATABASE_URL=mysql://user:pass@localhost:3306/fudaclub

# ── Auth ──────────────────────────────────────────────────────────────────────
# 64-char random hex string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates all sessions; pick once and keep stable.
JWT_SECRET=replace_me_with_64_random_hex_chars

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must include:
#   {PUBLIC_URL}/api/oauth/callback
# (so for Railway preview: https://fudaclub-production.up.railway.app/api/oauth/callback)
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-replace_me_with_real_google_secret

# ── Stripe (live mode for production) ─────────────────────────────────────────
# Find at https://dashboard.stripe.com/apikeys (toggle to Live mode top-right)
STRIPE_SECRET_KEY=sk_live_replace_me

# Webhook signing secret — created when you add a webhook endpoint in Stripe.
# Endpoint URL: {PUBLIC_URL}/api/stripe-webhook
# Events to subscribe: checkout.session.completed, customer.subscription.updated,
#                     customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── Square (kitchen receipts + POS) ───────────────────────────────────────────
# Optional but currently used for printing receipts on the in-store terminal.
# Get from https://developer.squareup.com/apps (Production tab for live)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# ── Legacy Manus vars (safe to leave empty on Railway) ────────────────────────
# Kept so old code that imports them doesn't crash. Do not set.
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
